# 应用配置
NODE_ENV=development
PORT=3000

# 数据库配置
DATABASE_URL=postgresql://postgres:password@localhost:5432/ai_web?schema=public

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT配置
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

# 前端地址（用于CORS）
FRONTEND_URL=http://localhost:5173

# 日志配置
LOG_LEVEL=info
LOG_DIR=./logs
